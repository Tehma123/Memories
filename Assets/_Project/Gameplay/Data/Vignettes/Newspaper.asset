  m_Name: Newspaper
  m_EditorClassIdentifier: Assembly-CSharp::VignetteData
  vignetteID: Newspaper
  vignetteType: 0
  textLines:
  - "\"MORNING HERALD \u2014 Vol. 1, No. 1\","
  - "\"\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\","
  - '"THE SUN AND THE EARTH IT LEFT BEHIND.",'
  - '" ",'
  - '"The sun believed it loved the earth.",'
  - '"So it burned brighter. And brighter. And brighter still.",'
  - '" ",'
  - '"It decided where the rivers would run.",'
  - '"It decided what the earth was allowed to feel.",'
  - '" ",'
  - '"The earth learned that love",'
  - '"sometimes has no shadow to rest in.",'
  - '" ",'
  - '"One morning, the earth was empty.",'
  - '"The sun still rose. Right on time.",'
  - '" ",'
  - "\"\u2500\u2500 No rain expected. No rain ever expected. \u2500\u2500\""
  displayEffects: 7
  audioCue: {fileID: 8300000, guid: 7bb94695a24b9d44e9890b216f5d43af, type: 3}
